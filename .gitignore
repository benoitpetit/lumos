# lumos project .gitignore file

# Lua bytecode files
*.luac

# LuaRocks build and install directories
.luarocks/
lua_modules/
deps/

# Temporary files
*.bak
*.tmp

# OS generated files
.DS_Store
Thumbs.db

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage reports
*.stats.out

# tmp folder
tmp/

# Generated documentation artifacts
docs/*.txt

# Distribution / bundle outputs
dist/

# Lumos cache
.lumos/

# Cross-compilation stubs and libraries
runtime/lib/*
!runtime/lib/windows-x86_64/
!runtime/lib/windows-x86_64/liblua.a
!runtime/lib/windows-x86_64/include/
!runtime/lib/windows-x86_64/include/*.h
!runtime/lib/linux-x86_64/
!runtime/lib/linux-x86_64/liblua.a
!runtime/lib/linux-x86_64/include/
!runtime/lib/linux-x86_64/include/*.h
!runtime/lib/darwin-x86_64/
!runtime/lib/darwin-x86_64/liblua.a
!runtime/lib/darwin-x86_64/include/
!runtime/lib/darwin-x86_64/include/*.h
!runtime/lib/darwin-aarch64/
!runtime/lib/darwin-aarch64/liblua.a
!runtime/lib/darwin-aarch64/include/
!runtime/lib/darwin-aarch64/include/*.h

!runtime/lib/linux-aarch64/
!runtime/lib/linux-aarch64/liblua.a
!runtime/lib/linux-aarch64/include/
!runtime/lib/linux-aarch64/include/*.h

# Editor backups
*~

# Environment / secret files
.env*

# Common build output directory
build/

# Added by Prompt My Project (PMP) - https://github.com/benoitpetit/prompt-my-project
pmp_output
whitepaper.md
*.src.rock

# e2e test artifacts
lumos-e2e-demo/