#!/usr/bin/env lua

-- Lumos CLI Generator
-- This script creates new CLI projects using the Lumos framework

-- Configure LuaRocks paths automatically
local PATH_SEP = package.config:sub(1, 1)
local function setup_luarocks_paths()
    local home = os.getenv("HOME") or os.getenv("USERPROFILE")
    if home then
        local version = _VERSION:match("%d+%.%d+") or "5.1"
        local lua_path = home .. PATH_SEP .. ".luarocks" .. PATH_SEP .. "share" .. PATH_SEP .. "lua" .. PATH_SEP .. version .. PATH_SEP .. "?.lua"
        local lua_cpath = home .. PATH_SEP .. ".luarocks" .. PATH_SEP .. "share" .. PATH_SEP .. "lua" .. PATH_SEP .. version .. PATH_SEP .. "?" .. PATH_SEP .. "init.lua"
        local ext = (PATH_SEP == "\\") and ".dll" or ".so"
        local lua_clib = home .. PATH_SEP .. ".luarocks" .. PATH_SEP .. "lib" .. PATH_SEP .. "lua" .. PATH_SEP .. version .. PATH_SEP .. "?" .. ext
        
        if not package.path:find(lua_path, 1, true) then
            package.path = lua_path .. ";" .. lua_cpath .. ";" .. package.path
        end
        if not package.cpath:find(lua_clib, 1, true) then
            package.cpath = lua_clib .. ";" .. package.cpath
        end
    end
end
setup_luarocks_paths()

-- Module loading with fallback for development and production
local function safe_require(module_name, fallback)
    local ok, result = pcall(require, module_name)
    if ok then
        return result
    end
    return fallback
end

-- Try to load from development path first (for local development)
local script_dir = debug.getinfo(1, 'S').source:match('^@(.+[/\\])') or './'
local dev_path = script_dir .. '../?.lua;' .. script_dir .. '../?/init.lua;'

-- Add development path temporarily for local development
local original_path = package.path
if not package.path:find(dev_path, 1, true) then
    package.path = dev_path .. package.path
end

-- Load Lumos modules
local lumos = safe_require('lumos')
if not lumos then
    -- Reset path and try system installation
    package.path = original_path
    lumos = safe_require('lumos')
end

local color = safe_require('lumos.color', {
    cyan = function(s) return s end,
    yellow = function(s) return s end,
    green = function(s) return s end,
    white = function(s) return s end,
    red = function(s) return s end,
    dim = function(s) return s end
})

local prompt = safe_require('lumos.prompt', {
    input = function(msg, default)
        io.write(msg .. (default and ' [' .. default .. ']' or '') .. ': ')
        local input = io.read()
        return (input and input ~= '') and input or default
    end
})

local lfs = safe_require('lfs')

-- Check dependencies
if not lumos then
    print("Error: Lumos framework not found.")
    print("Please install with: luarocks install lumos")
    os.exit(1)
end

if not lfs then
    print("Error: luafilesystem is required.")
    print("Please install with: luarocks install luafilesystem")
    os.exit(1)
end

-- Include the CLI logic inline since we can't easily require scripts/
-- Cross-platform recursive directory creation
local function mkdir_p(path)
    local sep = package.config:sub(1,1)
    -- Normalize mixed separators to native separator
    path = path:gsub("[/\\]", sep)
    local p = ''
    local is_absolute = path:sub(1, 1) == sep
    for dir in string.gmatch(path, "[^" .. sep .. "]+") do
        if p == '' then
            p = is_absolute and (sep .. dir) or dir
        else
            p = p .. sep .. dir
        end
        if not lfs.attributes(p, 'mode') then
            local ok, err = lfs.mkdir(p)
            if not ok then
                print('Error creating directory: ' .. p .. ' (' .. tostring(err) .. ')')
                return false
            end
        end
    end
    return true
end

local function write_file(path, content)
    local f = io.open(path, 'w')
    if not f then
        print('Error creating file: ' .. path)
        return false
    end
    f:write(content)
    f:close()
    return true
end

local function get_main_template(name, description)
    return [[#!/usr/bin/env lua
-- Main entry point for your CLI application

-- Configure LuaRocks paths automatically
local PATH_SEP = package.config:sub(1, 1)
local function setup_luarocks_paths()
    local home = os.getenv("HOME") or os.getenv("USERPROFILE")
    if home then
        local version = _VERSION:match("%d+%.%d+") or "5.1"
        local lua_path = home .. PATH_SEP .. ".luarocks" .. PATH_SEP .. "share" .. PATH_SEP .. "lua" .. PATH_SEP .. version .. PATH_SEP .. "?.lua"
        local lua_init = home .. PATH_SEP .. ".luarocks" .. PATH_SEP .. "share" .. PATH_SEP .. "lua" .. PATH_SEP .. version .. PATH_SEP .. "?" .. PATH_SEP .. "init.lua"
        local ext = (PATH_SEP == "\\") and ".dll" or ".so"
        local lua_clib = home .. PATH_SEP .. ".luarocks" .. PATH_SEP .. "lib" .. PATH_SEP .. "lua" .. PATH_SEP .. version .. PATH_SEP .. "?" .. ext

        if not package.path:find(lua_path, 1, true) then
            package.path = lua_path .. ";" .. lua_init .. ";" .. package.path
        end
        if not package.cpath:find(lua_clib, 1, true) then
            package.cpath = lua_clib .. ";" .. package.cpath
        end
    end
end
setup_luarocks_paths()

-- Configure module path to find app.lua in src directory
local script_dir = debug.getinfo(1, 'S').source:match("^@(.+[/\\])")
if script_dir then
    package.path = script_dir .. "?.lua;" .. script_dir .. "?/init.lua;" .. script_dir .. "../../?.lua;" .. script_dir .. "../../?/init.lua;" .. package.path
end

-- Load the application module
local ok, app = pcall(require, 'app')
if not ok then
    io.stderr:write("Error: module 'app' not found or failed to load.\n")
    io.stderr:write("Details: " .. tostring(app) .. "\n")
    io.stderr:write("Current directory: " .. (os.getenv("PWD") or ".") .. "\n")
    os.exit(1)
end

-- Run the application with command-line arguments
os.exit(app.run(arg))
]]
end

local function get_module_template(name, description)
    return string.format([[-- %s - Main Application Module
-- Generated by Lumos CLI Framework

-- Load Lumos framework
local lumos = require('lumos')
local color = require('lumos.color')

local M = {}

function M.run(args)
    -- Create the main application
    local app = lumos.new_app({
        name = "%s",
        version = "__APP_VERSION__",
        description = "%s"
    })

    -- Add global flags
    app:flag("-v --verbose", "Enable verbose output")

    -- Define the greet command (example)
    local greet = app:command("greet", "Greet someone politely")
    greet:arg("name", "Name of the person to greet")
    greet:flag("-u --uppercase", "Display greeting in uppercase")
    greet:flag("-c --colorful", "Use colored output")
    
    greet:action(function(ctx)
        local name = ctx.args[1] or "World"
        local message = "Hello, " .. name .. "!"
        
        if ctx.flags.uppercase then
            message = message:upper()
        end
        
        if ctx.flags.colorful then
            message = color.green(message)
        else
            message = color.white(message)
        end
        
        if ctx.flags.verbose then
            print(color.dim("Greeting generated for: " .. name))
        end
        
        print(message)
        return true
    end)
    
    -- Run the application
    return app:run(args)
end

return M
]], name, name, description)
end
local function get_test_template(name)
    return [[-- Basic test for app
local app = require('app')

describe("App CLI", function()
    it("should run without error", function()
        assert.has_no.errors(function()
            app.run({"greet", "TestUser"})
        end)
    end)
end)
]]
end

local function get_readme_template(name)
    return string.format([[# %s CLI Project

This project was generated with `lumos new`.

## Structure

- `src/app.lua` : Main CLI module
- `src/main.lua` : Entrypoint script
- `tests/app_spec.lua` : Example test (busted)
- `Makefile` : Build automation
- `.busted` : Busted test configuration
- `.gitignore` : Git ignore patterns
- `%s-dev-1.rockspec` : LuaRocks package specification

## Getting Started

### Run the application
```bash
lua src/main.lua greet Alice
# or
make run
```

### Install dependencies
```bash
make install
```

### Run tests
```bash
make test
# or
busted tests/
```

### Build documentation
```bash
lua src/main.lua --help
```

## Build & Distribution

This project supports multiple build modes via Lumos. By default, builds target your **host platform only**. Use `make dist-all` to build for every supported platform.

### Host platform (default)
```bash
make bundle     # Portable Lua script
make package    # Standalone executable
make build      # Native binary
```

### Specific platforms
```bash
# Package
make package-linux          # Linux x86_64
make package-linux-aarch64  # Linux ARM64
make package-windows        # Windows x86_64
make package-macos-x64      # macOS Intel
make package-macos-arm64    # macOS Apple Silicon

# Native build (requires C toolchain)
make build-linux            # Linux x86_64
make build-linux-aarch64    # Linux ARM64
make build-windows          # Windows x86_64
```

### Versioning
All output files include the version automatically:
```bash
make package VERSION=1.2.3
# → dist/%%s-1.2.3

make dist VERSION=1.2.3
# → dist/%%s-1.2.3-bundle.lua, dist/%s-1.2.3, dist/%s-1.2.3-native
```

### Build everything
```bash
make dist-all VERSION=1.2.3
```

## Key Features

- Command aliases and subcommands
- Advanced flag types and validation
- Configuration management
- Shell completions and man pages

## Development

To contribute to this project, please refer to the [Lumos documentation](https://github.com/benoitpetit/lumos) for more advanced features and development practices.

## License

MIT License
]], name, name, name, name, name)
end

local function get_rockspec_template(name, description)
    return string.format([=[package = "%s"
version = "dev-1"
source = {
    url = "git+https://github.com/YOUR_USERNAME/%s.git"
}
description = {
    summary = "%s",
    detailed = [[%s]],
    homepage = "https://github.com/YOUR_USERNAME/%s",
    license = "MIT"
}
dependencies = {
    "lua >= 5.1",
    "lumos",
    "luafilesystem"
}
build = {
    type = "builtin",
    modules = {
        ["%s.app"] = "src/app.lua"
    },
    install = {
        bin = {
            ["%s"] = "src/main.lua"
        }
    }
}
]=], name, name, description, description, name, name, name)
end

-- Main CLI application
local app = lumos.new_app({
    name = "lumos",
    version = lumos.version,
    description = "Lumos CLI framework and project generator"
})

local function run_new_project(ctx)
        print(color.cyan("Welcome to the Lumos CLI project generator!"))
        local project_name = ctx.args[1] or prompt.input("Project name", "myapp") or "myapp"
        
        -- Check if project directory already exists
        if lfs.attributes(project_name, "mode") == "directory" then
            print(color.yellow("\nWarning: Directory '" .. project_name .. "' already exists!"))
            io.write("Do you want to overwrite it? [y/N]: ")
            local answer = io.read()
            if not answer or answer:lower() ~= "y" then
                print(color.yellow("Cancelled."))
                return false
            end
        end
        
        local description = prompt.input("Project description", "A CLI app built with Lumos") or "A CLI app built with Lumos"
        print(color.yellow("Creating project structure for " .. project_name .. " ..."))

        -- Extract basename for internal file names
        local project_basename = project_name:match("[/\\]([^/\\]+)$") or project_name

        -- Create directories
        local ok_dirs = mkdir_p(project_name .. "/src")
        if not ok_dirs then
            print(color.red("Failed to create project directories."))
            return false
        end
        mkdir_p(project_name .. "/tests")
        mkdir_p(project_name .. "/docs")

        -- Create files
        write_file(project_name .. "/src/main.lua", get_main_template(project_basename, description))
        local app_lua = get_module_template(project_basename, description)
        app_lua = app_lua:gsub('"__APP_VERSION__"', '"0.1.0"')
        write_file(project_name .. "/src/app.lua", app_lua)
        write_file(project_name .. "/tests/app_spec.lua", get_test_template(project_basename))
        write_file(project_name .. "/README.md", get_readme_template(project_basename))

        -- Create rockspec
        write_file(project_name .. "/" .. project_basename .. "-dev-1.rockspec", get_rockspec_template(project_basename, description))
        
        -- Create Makefile
        write_file(project_name .. "/Makefile", string.format([[# %s CLI Project Makefile
# Generated by Lumos CLI Framework

NAME    ?= %s
VERSION ?= dev
ENTRY   := src/main.lua
DIST_DIR := dist

# Host platform detection
UNAME_S := $(shell uname -s)
UNAME_M := $(shell uname -m)
ifeq ($(UNAME_S),Linux)
    HOST_TARGET := linux-x86_64
    ifeq ($(UNAME_M),aarch64)
        HOST_TARGET := linux-aarch64
    endif
endif
ifeq ($(UNAME_S),Darwin)
    HOST_TARGET := darwin-x86_64
    ifeq ($(UNAME_M),arm64)
        HOST_TARGET := darwin-aarch64
    endif
endif

LUA ?= lua
LUMOS ?= $(shell command -v lumos 2>/dev/null || echo $(HOME)/.luarocks/bin/lumos)

# Check if Lumos is installed
check-lumos:
	@luarocks show lumos >/dev/null 2>&1 || { echo "Error: Lumos not found. Run 'make install' first."; exit 1; }

install: check-lumos
	@echo "Installing development dependencies..."
	@luarocks install --local luafilesystem || echo "Warning: could not install luafilesystem"
	@luarocks install --local busted || echo "Warning: could not install busted"
	@luarocks make --local $(NAME)-dev-1.rockspec || echo "Warning: could not install local rockspec"
	@echo "✓ Dependencies installed"

test: check-lumos
	@echo "Running tests..."
	@busted tests/ || ~/.luarocks/bin/busted tests/ || echo "Error: busted not found in PATH"

run: check-lumos
	@echo "Running application..."
	@lua $(ENTRY) greet World

help: check-lumos
	@lua $(ENTRY) --help

dev: check-lumos
	@echo "Development mode - running with example args:"
	@lua $(ENTRY) --verbose greet "Developer"

# Build for the host platform (default)
bundle: check-lumos ensure-dist
	@echo "Bundling portable Lua script..."
	@$(LUMOS) bundle $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-bundle.lua --app-version $(VERSION)

package: check-lumos ensure-dist
	@echo "Packaging for host ($(HOST_TARGET))..."
	@$(LUMOS) package $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION) -t $(HOST_TARGET) --app-version $(VERSION)

build: check-lumos ensure-dist
	@echo "Building native binary for host ($(HOST_TARGET))..."
	@$(LUMOS) build $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-native -t $(HOST_TARGET) --app-version $(VERSION)

# Platform-specific packaging
package-linux: check-lumos ensure-dist
	@echo "Packaging Linux x86_64 executable..."
	@$(LUMOS) package $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-linux-x86_64 -t linux-x86_64 --app-version $(VERSION)

package-linux-aarch64: check-lumos ensure-dist
	@echo "Packaging Linux aarch64 executable..."
	@$(LUMOS) package $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-linux-aarch64 -t linux-aarch64 --app-version $(VERSION)

package-windows: check-lumos ensure-dist
	@echo "Packaging Windows executable..."
	@$(LUMOS) package $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-win.exe -t windows-x86_64 --app-version $(VERSION)

package-macos-x64: check-lumos ensure-dist
	@echo "Packaging macOS x86_64 executable..."
	@$(LUMOS) package $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-macos-x86_64 -t darwin-x86_64 --app-version $(VERSION)

package-macos-arm64: check-lumos ensure-dist
	@echo "Packaging macOS arm64 executable..."
	@$(LUMOS) package $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-macos-arm64 -t darwin-aarch64 --app-version $(VERSION)

# Platform-specific native builds
build-linux: check-lumos ensure-dist
	@echo "Building native Linux x86_64 binary..."
	@$(LUMOS) build $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-linux-x86_64-native -t linux-x86_64 --app-version $(VERSION)

build-linux-aarch64: check-lumos ensure-dist
	@echo "Building native Linux aarch64 binary..."
	@$(LUMOS) build $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-linux-aarch64-native -t linux-aarch64 --app-version $(VERSION)

build-windows: check-lumos ensure-dist
	@echo "Building native Windows binary..."
	@$(LUMOS) build $(ENTRY) -d . -o $(DIST_DIR)/$(NAME)-$(VERSION)-win.exe-native -t windows-x86_64 --app-version $(VERSION)

# Default dist: build for host platform only
dist: bundle package build
	@echo "✓ Built $(NAME) v$(VERSION) for $(HOST_TARGET) in $(DIST_DIR)/"

# Build for all supported platforms
dist-all: bundle package-linux package-linux-aarch64 package-windows package-macos-x64 package-macos-arm64 build-linux build-linux-aarch64 build-windows
	@echo "✓ Built $(NAME) v$(VERSION) for all platforms in $(DIST_DIR)/"

clean:
	@echo "Cleaning build artifacts..."
	@rm -rf $(DIST_DIR) docs/*.txt *.log

ensure-dist:
	@mkdir -p $(DIST_DIR)

.PHONY: check-lumos install test run help dev bundle package build package-linux package-linux-aarch64 package-windows package-macos-x64 package-macos-arm64 build-linux build-linux-aarch64 build-windows dist dist-all clean ensure-dist
]], project_basename, project_basename))
        
        -- Create .gitignore
        write_file(project_name .. "/.gitignore", [[# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Build artifacts
dist/
docs/*.txt
*.log

# Local configuration
config.local.lua

# LuaRocks
.luarocks/
]])
        
        -- Create .busted configuration
        write_file(project_name .. "/.busted", [[return {
  default = {
    verbose = true,
    coverage = false,
    pattern = ".*_spec%.lua$",
    ROOT = {"tests/"}
  }
}
]])
        
        print(color.green("\n✅ Lumos CLI project '" .. project_name .. "' created successfully!"))
        print(color.white("\nNext steps:"))
        print("  cd " .. project_name)
        print("  make install          # Install dependencies")
        print("  make run              # Run the application")
        print("  make test             # Run tests")
        print("  make bundle           # Create portable Lua bundle (host platform)")
        print("  make package          # Create standalone executable (host platform)")
        print("  make build            # Create native binary (host platform)")
        print("  make dist             # Build bundle + package + build for host")
        print("  make dist-all         # Build for all supported platforms")
        print(color.dim("\nTip: set a custom version with --app-version (e.g. lumos package src/main.lua --app-version 1.0.0)"))
        
        return true
    end

app:command("new", "Create a new Lumos CLI project")
    :arg("name", "Project name (optional)")
    :action(run_new_project)

app:command("create", "Alias for 'new'")
    :arg("name", "Project name (optional)")
    :action(run_new_project)

app:command("version", "Show Lumos version")
    :action(function(ctx)
        print("Lumos CLI Framework v" .. (lumos.version or "0.3.8"))
        print("A modern CLI framework for Lua")
        print("https://github.com/benoitpetit/lumos")
        return true
    end)

app:command("update", "Update Lumos to the latest version via LuaRocks")
    :action(function(ctx)
        print(color.cyan("Updating Lumos..."))
        print(color.white("Current version: v" .. (lumos.version or "0.3.8")))
        print("")

        local cmd = "luarocks install lumos"
        print(color.yellow("Running: " .. cmd))
        local ok = os.execute(cmd)

        if ok then
            print("")
            print(color.green("✅ Lumos updated successfully!"))
            -- Try to reload to show new version
            local new_lumos, _ = pcall(require, 'lumos')
            if new_lumos and require('lumos').version then
                print(color.white("New version: v" .. require('lumos').version))
            else
                print(color.yellow("Restart your shell to use the updated version."))
            end
        else
            print("")
            print(color.red("❌ Update failed."))
            print(color.yellow("Try running manually:"))
            print(color.white("  luarocks install --local lumos"))
            print(color.white("  sudo luarocks install lumos"))
            return false
        end
        return true
    end)

app:command("doctor", "Check the Lumos environment for common issues")
    :action(function(ctx)
        print(color.cyan("Lumos Environment Check"))
        print(string.rep("-", 40))

        local checks = {}
        local issues = 0
        local warnings = 0

        local function add_check(label, value, level)
            table.insert(checks, { label, value })
            if level == "error" then
                issues = issues + 1
            elseif level == "warn" then
                warnings = warnings + 1
            end
        end

        local null_dev = (package.config:sub(1,1) == "\\") and " 2>nul" or " 2>/dev/null"
        local function first_line(cmd)
            local handle = io.popen(cmd .. null_dev)
            local out = handle and handle:read("*l") or nil
            if handle then handle:close() end
            if out and out ~= "" then
                return out
            end
            return nil
        end

        add_check("Lua version", _VERSION or "unknown")

        local lfs_ok, lfs_ver = pcall(function()
            return lfs._VERSION or "installed"
        end)
        if lfs_ok then
            add_check("luafilesystem", lfs_ver)
        else
            add_check("luafilesystem", color.red("NOT FOUND"), "error")
        end

        add_check("Lumos", lumos and lumos.version or color.red("NOT FOUND"), (not lumos) and "error" or nil)

        local lr_out = first_line("luarocks --version")
        if lr_out then
            add_check("LuaRocks", lr_out)
        else
            add_check("LuaRocks", color.red("NOT FOUND"), "error")
        end

        local b_out = first_line("busted --version")
        if b_out then
            add_check("busted", b_out)
        else
            add_check("busted", color.yellow("not installed (optional)"), "warn")
        end

        local native_build = safe_require('lumos.native_build')
        if native_build then
            local compiler = native_build.detect_compiler()
            if compiler then
                add_check("C compiler", compiler)
            else
                add_check("C compiler", color.yellow("NOT FOUND (required for lumos build)"), "warn")
            end

            local tc, tc_err = native_build.detect_toolchain()
            if tc then
                local details = "headers=" .. (tc.lua_include_dir or "?")
                if tc.liblua_path then
                    details = details .. ", lib=" .. tc.liblua_path
                end
                add_check("Lua build toolchain", details)
            else
                add_check("Lua build toolchain", color.yellow("incomplete (" .. tostring(tc_err or "unknown") .. ")"), "warn")
            end
        else
            add_check("Native build module", color.red("NOT FOUND"), "error")
        end

        local pkg_mod = safe_require('lumos.package')
        if pkg_mod then
            local targets = pkg_mod.list_targets()
            if #targets > 0 then
                add_check("Launchers", table.concat(targets, ", "))
            else
                add_check("Launchers", color.yellow("none found (required for lumos package)"), "warn")
            end

            local host_target = pkg_mod.detect_host_target()
            local host_launcher = pkg_mod.find_launcher(host_target)
            if host_launcher then
                add_check("Host launcher", host_target)
            else
                add_check("Host launcher", color.yellow("missing for " .. host_target), "warn")
            end
        else
            add_check("Package module", color.red("NOT FOUND"), "error")
        end

        add_check("Working directory", lfs.currentdir() or ".")

        for _, check in ipairs(checks) do
            print(string.format("  %-18s %s", check[1] .. ":", check[2]))
        end

        print(string.rep("-", 40))
        if issues == 0 and warnings == 0 then
            print(color.green("✅ Environment looks good."))
            return true
        end
        if issues == 0 then
            print(color.yellow("⚠️  Environment is usable with " .. warnings .. " warning(s)."))
            return true
        end

        print(color.red("⚠️  Found " .. issues .. " blocking issue(s)."))
        return false
    end)

-- Bundle command for creating portable CLI executables
local bundle_cmd = app:command("bundle", "Bundle a Lumos CLI project into a single portable Lua script (requires Lua interpreter on target)")
bundle_cmd:arg("entry", "Entry point file (e.g., src/main.lua)")
bundle_cmd:flag_string("-o --output", "Output file path (default: dist/<name>)")
bundle_cmd:flag_string("-d --dir", "Project directory (default: current directory)")
bundle_cmd:flag("--no-lumos", "Do not bundle Lumos framework (requires Lumos installed on target)")
bundle_cmd:flag("--strip-comments", "Remove comments to reduce file size")
bundle_cmd:flag("--analyze", "Analyze dependencies without creating bundle")

bundle_cmd:action(function(ctx)
    local bundle = safe_require('lumos.bundle')
    if not bundle then
        print(color.red("Error: Bundle module not found."))
        return false
    end
    
    local entry_file = ctx.args[1]
    if not entry_file then
        print(color.red("Error: Entry file is required."))
        print(color.yellow("Usage: lumos bundle <entry_file> [options]"))
        print(color.yellow("Example: lumos bundle src/main.lua -o dist/myapp"))
        return false
    end
    
    -- Check if entry file exists and is a regular file
    if not lfs.attributes(entry_file) then
        print(color.red("Error: Entry file not found: " .. entry_file))
        return false
    end
    if lfs.attributes(entry_file, "mode") ~= "file" then
        print(color.red("Error: Entry path is not a file: " .. entry_file))
        return false
    end
    
    local project_dir = ctx.flags.dir or "."
    
    -- Analyze mode
    if ctx.flags.analyze then
        print(color.cyan("Analyzing dependencies for: " .. entry_file))
        local modules = bundle.analyze(entry_file, {project_dir, project_dir .. "/src", project_dir .. "/lib", "."})
        
        if #modules == 0 then
            print(color.yellow("No local dependencies found."))
        else
            print(color.green("\nFound " .. #modules .. " dependencies:"))
            for i, mod in ipairs(modules) do
                print(string.format("  %d. %s", i, mod.name))
                print(color.white("     -> " .. mod.path))
            end
        end
        
        if not ctx.flags["no_lumos"] and bundle then
            print(color.cyan("\nLumos modules will also be bundled:"))
            local lumos_mods = bundle.get_lumos_modules()
            for _, mod_name in ipairs(lumos_mods) do
                print("  - " .. mod_name)
            end
        end
        
        return true
    end
    
    -- Bundle mode
    print(color.cyan("Bundling CLI application..."))
    print(color.white("  Entry: " .. entry_file))
    
    local options = {
        entry = entry_file,
        output = ctx.flags.output,
        project_dir = project_dir,
        include_lumos = not ctx.flags["no_lumos"],
        strip_comments = ctx.flags["strip_comments"],
        version = ctx.flags["app_version"],
    }
    
    local success, err, info = bundle.create(options)
    
    if not success then
        print(color.red("Error: " .. (err or "Unknown error")))
        return false
    end
    
    if info then
        print(color.green("\n✅ Bundle created successfully!"))
        print(color.white("  Output: " .. info.output))
        print(color.white("  Modules bundled: " .. info.modules_count))
        print(color.white("  Size: " .. string.format("%.2f KB", info.size / 1024)))
        print(color.yellow("\nYour bundled Lua script is ready!"))
        print(color.yellow("Note: the target machine needs a Lua interpreter installed."))
        print(color.yellow("Run it with: ./" .. info.output:match("([^/\\]+)$") .. " --help"))
    end
    
    return true
end)

-- Build command for creating native static binaries
local build_cmd = app:command("build", "Build a standalone native binary from a Lumos CLI project (no Lua runtime required on target)")
build_cmd:arg("entry", "Entry point file (e.g., src/main.lua)")
build_cmd:flag_string("-o --output", "Output binary path (default: dist/<name>)")
build_cmd:flag_string("-d --dir", "Project directory (default: current directory)")
build_cmd:flag("--no-lumos", "Do not bundle Lumos framework")
build_cmd:flag("--strip-comments", "Remove comments to reduce binary payload size")
build_cmd:flag_string("--cc", "Force a specific C compiler")
build_cmd:flag("--static", "Produce a fully statically linked binary")
build_cmd:flag("--bytecode", "Compile Lua payload to bytecode before embedding")
build_cmd:flag("--debug-build", "Keep temporary C source file for debugging")
build_cmd:flag_string("-t --target", "Target platform for cross-compilation (e.g. windows-x86_64)")
build_cmd:flag_string("--app-version", "Application version to embed (replaces __APP_VERSION__ in source)")

build_cmd:flag("--analyze", "Analyze dependencies without building")

build_cmd:action(function(ctx)
    local native_build = safe_require('lumos.native_build')
    if not native_build then
        print(color.red("Error: Native build module not found."))
        return false
    end
    
    local entry_file = ctx.args[1]
    if not entry_file then
        print(color.red("Error: Entry file is required."))
        print(color.yellow("Usage: lumos build <entry_file> [options]"))
        print(color.yellow("Example: lumos build src/main.lua -o dist/myapp"))
        return false
    end
    
    if not lfs.attributes(entry_file) then
        print(color.red("Error: Entry file not found: " .. entry_file))
        return false
    end
    if lfs.attributes(entry_file, "mode") ~= "file" then
        print(color.red("Error: Entry path is not a file: " .. entry_file))
        return false
    end
    
    local project_dir = ctx.flags.dir or "."
    
    -- Analyze mode (reuse bundle.analyze for consistent output)
    if ctx.flags.analyze then
        local bundle = safe_require('lumos.bundle')
        print(color.cyan("Analyzing dependencies for: " .. entry_file))
        local modules = bundle and bundle.analyze(entry_file, {project_dir, project_dir .. "/src", project_dir .. "/lib", "."}) or {}
        
        if #modules == 0 then
            print(color.yellow("No local dependencies found."))
        else
            print(color.green("\nFound " .. #modules .. " dependencies:"))
            for i, mod in ipairs(modules) do
                print(string.format("  %d. %s", i, mod.name))
                print(color.white("     -> " .. mod.path))
            end
        end
        
        if not ctx.flags["no_lumos"] then
            print(color.cyan("\nLumos modules will also be bundled:"))
            local lumos_mods = bundle.get_lumos_modules()
            for _, mod_name in ipairs(lumos_mods) do
                print("  - " .. mod_name)
            end
        end
        
        return true
    end
    
    print(color.cyan("Building native binary..."))
    print(color.white("  Entry: " .. entry_file))
    
    local options = {
        entry = entry_file,
        output = ctx.flags.output,
        project_dir = project_dir,
        include_lumos = not ctx.flags["no_lumos"],
        strip_comments = ctx.flags["strip_comments"],
        cc = ctx.flags.cc,
        static = ctx.flags.static,
        bytecode = ctx.flags.bytecode,
        debug_build = ctx.flags["debug_build"],
        target = ctx.flags.target,
        version = ctx.flags["app_version"],
    }
    
    local success, err, info = native_build.create(options)
    
    if not success then
        print(color.red("Error: " .. (err or "Unknown error")))
        return false
    end
    
    if info then
        print(color.green("\n✅ Native binary built successfully!"))
        print(color.white("  Output: " .. info.output))
        print(color.white("  Modules bundled: " .. info.modules_count))
        print(color.white("  Size: " .. string.format("%.2f KB", info.size / 1024)))
        print(color.white("  Compiler: " .. info.compiler))
        if info.bytecode then
            print(color.white("  Bytecode: enabled"))
        end
        if info.missing_native and #info.missing_native > 0 then
            print(color.yellow("  Warning: missing static archives for native modules: " .. table.concat(info.missing_native, ", ")))
        end
        if info.debug_build and info.main_c_path then
            print(color.cyan("  Debug build: kept C wrapper at " .. info.main_c_path))
        end
        if not info.static then
            print(color.yellow("  Warning: binary is dynamically linked to libc. Use --static for full portability."))
        end
        print(color.yellow("\nYour standalone CLI is ready!"))
        print(color.yellow("Run it with: ./" .. info.output:match("([^/\\]+)$") .. " --help"))
    end
    
    return true
end)

-- Package command for creating standalone executables without a C compiler
local package_cmd = app:command("package", "Package a Lumos CLI project into a standalone executable using a precompiled launcher")
package_cmd:arg("entry", "Entry point file (e.g., src/main.lua)")
package_cmd:flag_string("-o --output", "Output file path (default: dist/<name>)")
package_cmd:flag_string("-d --dir", "Project directory (default: current directory)")
package_cmd:flag_string("-t --target", "Target platform launcher (default: linux-x86_64)")
package_cmd:flag("--list-targets", "List available launcher targets and exit")
package_cmd:flag("--sync-runtime", "Download missing launchers before packaging")
package_cmd:flag("--no-lumos", "Do not bundle Lumos framework")
package_cmd:flag("--strip-comments", "Remove comments to reduce payload size")
package_cmd:flag_string("--app-version", "Application version to embed (replaces __APP_VERSION__ in source)")
package_cmd:flag("--analyze", "Analyze dependencies without building")

package_cmd:action(function(ctx)
    local pkg = safe_require('lumos.package')
    if not pkg then
        print(color.red("Error: Package module not found."))
        return false
    end
    
    if ctx.flags["list_targets"] then
        if ctx.flags["sync_runtime"] then
            local ok_sync, sync_err = pkg.sync_runtime()
            if not ok_sync then
                print(color.yellow("Runtime sync warning: " .. tostring(sync_err)))
            end
        end
        local targets = pkg.list_targets()
        print(color.cyan("Available launcher targets:"))
        if #targets == 0 then
            print(color.yellow("  No runtime launchers found."))
        else
            for _, t in ipairs(targets) do
                print("  - " .. t)
            end
        end
        return true
    end
    
    local entry_file = ctx.args[1]
    if not entry_file then
        print(color.red("Error: Entry file is required."))
        print(color.yellow("Usage: lumos package <entry_file> [options]"))
        print(color.yellow("Example: lumos package src/main.lua -o dist/myapp"))
        return false
    end
    
    if not lfs.attributes(entry_file) then
        print(color.red("Error: Entry file not found: " .. entry_file))
        return false
    end
    if lfs.attributes(entry_file, "mode") ~= "file" then
        print(color.red("Error: Entry path is not a file: " .. entry_file))
        return false
    end
    
    local project_dir = ctx.flags.dir or "."

    -- Analyze mode
    if ctx.flags.analyze then
        local bundle = safe_require('lumos.bundle')
        print(color.cyan("Analyzing dependencies for: " .. entry_file))
        local modules = bundle and bundle.analyze(entry_file, {project_dir, project_dir .. "/src", project_dir .. "/lib", "."}) or {}

        if #modules == 0 then
            print(color.yellow("No local dependencies found."))
        else
            print(color.green("\nFound " .. #modules .. " dependencies:"))
            for i, mod in ipairs(modules) do
                print(string.format("  %d. %s", i, mod.name))
                print(color.white("     -> " .. mod.path))
            end
        end

        if not ctx.flags["no_lumos"] and bundle then
            print(color.cyan("\nLumos modules will also be bundled:"))
            local lumos_mods = bundle.get_lumos_modules()
            for _, mod_name in ipairs(lumos_mods) do
                print("  - " .. mod_name)
            end
        end

        return true
    end

    local target = ctx.flags.target or pkg.detect_host_target()
    
    print(color.cyan("Packaging standalone executable..."))
    print(color.white("  Entry: " .. entry_file))
    print(color.white("  Target: " .. target))
    
    local options = {
        entry = entry_file,
        output = ctx.flags.output,
        project_dir = project_dir,
        target = target,
        include_lumos = not ctx.flags["no_lumos"],
        strip_comments = ctx.flags["strip_comments"],
        sync_runtime_force = ctx.flags["sync_runtime"],
        version = ctx.flags["app_version"],
    }
    
    local success, err, info = pkg.create(options)
    
    if not success then
        print(color.red("Error: " .. (err or "Unknown error")))
        return false
    end
    
    if info then
        print(color.green("\n✅ Package created successfully!"))
        print(color.white("  Output: " .. info.output))
        print(color.white("  Target: " .. info.target))
        print(color.white("  Modules bundled: " .. info.modules_count))
        print(color.white("  Total size: " .. string.format("%.2f KB", info.size / 1024)))
        print(color.white("  Launcher size: " .. string.format("%.2f KB", info.launcher_size / 1024)))
        print(color.yellow("\nYour standalone CLI is ready!"))
        print(color.yellow("Run it with: ./" .. info.output:match("([^/\\]+)$") .. " --help"))
    end
    
    return true
end)

app:add_completion_command()

os.exit(app:run(arg))
